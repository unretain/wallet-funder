# Copy this file to .env and fill in your values.
# The web UI can auto-generate BUNDLE_KEY for you on first run —
# you only strictly need RPC_URL.

# Fast private RPC — Helius / Triton / QuickNode recommended
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Bundle holder wallet (auto-generated by the UI if left blank).
# Format: JSON array of secret bytes  e.g. [1,2,3,...]
BUNDLE_KEY=

# Path to generated wallets file (relative to this folder)
WALLETS_PATH=./wallets.json

# Number of buyer wallets to generate
WALLET_COUNT=100
